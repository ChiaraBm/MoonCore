<CascadingValue TValue="Accordion" IsFixed="true" Value="@this">
  @ChildContent
</CascadingValue>

<div class="accordion divide-neutral/20 divide-y">
  @foreach (var item in Items)
  {
    var isActive = SelectedItem == item;

    <div class="accordion-item @(isActive ? "active" : "")">
      <button @onclick="() => Select(item)" class="accordion-toggle inline-flex items-center gap-x-4 text-start items-center"
              aria-expanded="true">
        @item.Header.Invoke(isActive)
      </button>
      <div
        class="grid overflow-hidden transition-all duration-300 ease-in-out @(isActive ? "grid-rows-[1fr] opacity-100" : "grid-rows-[0fr] opacity-0")"
        role="region">
        <div class="overflow-hidden">
          @item.Body
        </div>
      </div>
    </div>
  }
</div>

@code
{
  [Parameter] public RenderFragment ChildContent { get; set; }

  private readonly List<AccordionItem> Items = new();
  private AccordionItem? SelectedItem;

  private bool InTransition = false;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (!firstRender)
      return;

    SelectedItem = Items.FirstOrDefault();
    await InvokeAsync(StateHasChanged);
  }

  private async Task Select(AccordionItem item)
  {
    if (SelectedItem == item)
      SelectedItem = null; // Unselect if clicked on the current item
    else
      SelectedItem = item; // Select the citem

    InTransition = true;
    await InvokeAsync(StateHasChanged);

    Task.Run(async () =>
    {
      await Task.Delay(TimeSpan.FromMilliseconds(500));

      InTransition = false;
      await InvokeAsync(StateHasChanged);
    });
  }

  public void AddItem(AccordionItem item)
  {
    Items.Add(item);
  }
}