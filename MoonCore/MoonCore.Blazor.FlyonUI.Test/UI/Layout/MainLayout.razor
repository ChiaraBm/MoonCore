@inherits LayoutComponentBase

<div class="relative isolate flex min-h-svh w-full max-lg:flex-col bg-base-300">
    <AppSidebar Layout="this"/>
    <AppHeader Layout="this" />

    <main class="flex flex-1 flex-col lg:pb-5 lg:min-w-0 lg:pt-5 lg:pr-3.5 lg:pl-64">
        <div class="grow p-6 lg:rounded-lg lg:py-10 lg:px-5 lg:ring-1 lg:shadow-xs lg:bg-base-200/40 lg:ring-base-content/10">
            <div class="mx-auto max-w-7xl">
                <CascadingValue Value="this" IsFixed="true">
                    @Body
                </CascadingValue>
            </div>
        </div>
    </main>

</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code
{
    // Mobile navigation
    public event Func<Task> OnStateChanged;
    public bool ShowMobileNavigation { get; private set; } = false;

    public async Task ToggleMobileNavigation()
    {
        ShowMobileNavigation = !ShowMobileNavigation;
        await OnStateChanged();
    }
}