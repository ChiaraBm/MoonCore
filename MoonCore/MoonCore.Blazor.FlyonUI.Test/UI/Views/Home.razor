@page "/"
@using MoonCore.Blazor.FlyonUI.Components

<PageTitle>Home</PageTitle>

<div class="mt-5 flex justify-center">

    <div class="gap-5 w-full grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4">
        <div class="col-span-1 stats">
            <div class="stat">
                <div class="stat-figure">
                    <i class="icon-cpu text-3xl text-primary"></i>
                </div>
                <div class="stat-title">CPU Usage</div>
                <div class="stat-value truncate">1,5%</div>
            </div>
        </div>

        <div class="col-span-1 stats">
            <div class="stat">
                <div class="stat-figure">
                    <i class="icon-memory-stick text-3xl text-primary"></i>
                </div>
                <div class="stat-title">Memory Usage</div>
                <div class="stat-value truncate">635.52 MB</div>
            </div>
        </div>

        <div class="col-span-1 stats">
            <div class="stat">
                <div class="stat-figure">
                    <i class="icon-server-cog  text-3xl text-primary"></i>
                </div>
                <div class="stat-title">Running on</div>
                <div class="stat-value truncate">
                    Ubuntu
                </div>
            </div>
        </div>

        <div class="col-span-1 stats">
            <div class="stat">
                <div class="stat-figure">
                    <i class="icon-clock  text-3xl text-primary"></i>
                </div>
                <div class="stat-title">Uptime</div>
                <div class="stat-value truncate">5d 18h 27m</div>
            </div>
        </div>

        <div class="col-span-1 card card-body">
            <div class="flex justify-center items-center">
                <WButton OnClick="Restart" CssClasses="btn btn-error w-full">
                    <i class="icon-repeat text-xl text-white me-2"></i>
                    Restart/Shutdown
                </WButton>
            </div>
        </div>
        
        <div class="col-span-1 card card-body">
            <div class="flex justify-center items-center">
                <WButton OnClick="Test" CssClasses="btn btn-primary w-full">
                    Test
                </WButton>
            </div>
        </div>
    </div>
</div>

@code
{
    private async Task Restart(WButton button)
    {
        await button.UpdateLoadingText("Notifying plugins");
        await Task.Delay(TimeSpan.FromSeconds(1));

        await button.UpdateLoadingText("Stopping services");
        await Task.Delay(TimeSpan.FromSeconds(1));

        await button.UpdateLoadingText("Waiting for startup");
        await Task.Delay(TimeSpan.FromSeconds(5));

        await button.UpdateLoadingText("Starting services");
        await Task.Delay(TimeSpan.FromSeconds(1));
    }

    private async Task Test(WButton _)
    {
        throw new Exception("AAAAAA");
    }
}
